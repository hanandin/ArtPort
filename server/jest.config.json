{
  "testEnvironment": "node",
  "transform": {},
  "testMatch": ["**/__tests__/**/*.js", "**/?(*.)+(spec|test).js"],
  "collectCoverageFrom": [
    "src/**/*.js",
    "!src/**/*.test.js",
    "!src/config/**",
    "!src/middleware/upload.js"
  ],
  "coveragePathIgnorePatterns": ["/node_modules/"],
  "testTimeout": 10000,
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  }
}
