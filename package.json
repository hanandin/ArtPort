{
  "name": "artport",
  "version": "1.0.0",
  "description": "ArtPort - The portal to all artists",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd frontend-next && npm run dev",
    "build": "npm run build:server && npm run build:client",
    "build:server": "cd server && npm run build",
    "build:client": "cd frontend-next && npm run build",
    "start": "concurrently \"npm run start:server\" \"npm run start:client\"",
    "start:server": "cd server && npm run start",
    "start:client": "cd frontend-next && npm run start",
    "install-all": "npm install && cd server && npm install && cd ../frontend-next && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@2toad/profanity": "^3.3.0"
  }
}
